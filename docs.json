{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Toine Scripts Docs",
  "colors": {
    "primary": "#811b1b",
    "light": "#811b1b",
    "dark": "#811b1b"
  },
  "favicon": "/images/TS.png",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Store",
          "icon": "shopping-cart",
          "href": "https://store.toine.me"
        }
      ]
    },
    "languages": [
      {
        "language": "en",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Scripts",
            "pages": [
              {
                "group": "TS-Lib",
                "pages": [
                  "scripts/ts-lib/index",
                  "scripts/ts-lib/api-reference",
                  "scripts/ts-lib/bridges-framework",
                  "scripts/ts-lib/bridges-garages",
                  "scripts/ts-lib/bridges-vehiclekeys",
                  "scripts/ts-lib/contributing"
                ]
              },
              {
                "group": "Persistence",
                "pages": [
                  "scripts/persistance/index",
                  "scripts/persistance/installation",
                  "scripts/persistance/config",
                  "scripts/persistance/commands",
                  "scripts/persistance/events",
                  {
                    "group": "Exports",
                    "pages": [
                      "scripts/persistance/exports/client",
                      "scripts/persistance/exports/server"
                    ]
                  },
                  "scripts/persistance/data-structure",
                  "scripts/persistance/examples",
                  {
                    "group": "Plugins",
                    "pages": [
                      "scripts/persistance/plugins/index",
                      "scripts/persistance/plugins/vehicle-deformation"
                    ]
                  },
                  "scripts/persistance/data-structure",
                  "scripts/persistance/issues",
                  "scripts/persistance/changelog"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "fr",
        "groups": [
          {
            "group": "Pour commencer",
            "pages": [
              "fr/index"
            ]
          },
          {
            "group": "Scripts",
            "pages": [
              {
                "group": "TS-Lib",
                "pages": [
                  "fr/scripts/ts-lib/index",
                  "fr/scripts/ts-lib/api-reference",
                  "fr/scripts/ts-lib/bridges-framework",
                  "fr/scripts/ts-lib/bridges-garages",
                  "fr/scripts/ts-lib/bridges-vehiclekeys",
                  "fr/scripts/ts-lib/contributing"
                ]
              },
              {
                "group": "Persistance",
                "pages": [
                  "fr/scripts/persistance/index",
                  "fr/scripts/persistance/installation",
                  "fr/scripts/persistance/config",
                  "fr/scripts/persistance/commands",
                  "fr/scripts/persistance/events",
                  {
                    "group": "Exports",
                    "pages": [
                      "fr/scripts/persistance/exports/client",
                      "fr/scripts/persistance/exports/server"
                    ]
                  },
                  "fr/scripts/persistance/data-structure",
                  "fr/scripts/persistance/examples",
                  {
                    "group": "Plugins",
                    "pages": [
                      "fr/scripts/persistance/plugins/index",
                      "fr/scripts/persistance/plugins/vehicle-deformation"
                    ]
                  },
                  "fr/scripts/persistance/data-structure",
                  "fr/scripts/persistance/issues",
                  "fr/scripts/persistance/changelog"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/ts_logo_large.svg",
    "dark": "/images/ts_logo_large.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Store",
      "href": "https://store.toine.me"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "website": "https://store.toine.me",
      "discord": "https://discord.gg/4dv9FB6g4G"
    }
  },
  "description": "You can find here all the infos about our scripts.",
  "background": {
    "decoration": "grid"
  },
  "appearance": {
    "strict": true,
    "default": "dark"
  },
  "fonts": {
    "family": "Montserrat"
  },
  "metadata": {
    "timestamp": true
  }
}
